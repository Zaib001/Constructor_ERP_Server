  company   Company           @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project   Project           @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  invoices  ProgressInvoice[]
  snapshots CostTracking[]

  @@index([company_id, project_id])
  @@map("billing_cycles")
  @@schema("auth")
}

// ─── Cost Tracking (Snapshots) ────────────────────────────────────────────────
model CostTracking {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id      String   @db.Uuid
  project_id      String   @db.Uuid
  cycle_id        String?  @db.Uuid
  wbs_id          String?  @db.Uuid
  planned_amount  Decimal  @default(0) @db.Decimal
  committed_amount Decimal @default(0) @db.Decimal
  actual_amount   Decimal  @default(0) @db.Decimal
  variance        Decimal  @default(0) @db.Decimal
  recorded_at     DateTime @default(now()) @db.Timestamp(6)

  company Company       @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project Project       @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cycle   BillingCycle? @relation(fields: [cycle_id], references: [id])
  wbs     WBS?          @relation(fields: [wbs_id], references: [id])

  @@index([company_id, project_id, cycle_id])
  @@map("cost_tracking")
  @@schema("auth")
}

model ProgressInvoiceItem {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_id      String  @db.Uuid
  wbs_id          String  @db.Uuid
  boq_item_id     String? @db.Uuid
  description     String  @db.VarChar(500)
  unit            String? @db.VarChar(50)
  contract_qty    Decimal @db.Decimal
  unit_rate       Decimal @db.Decimal
  contract_amount Decimal @db.Decimal
  prev_pct        Decimal @default(0) @db.Decimal
  this_pct        Decimal @db.Decimal
  cumul_pct       Decimal @db.Decimal
  this_amount     Decimal @db.Decimal

  invoice  ProgressInvoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wbs      WBS             @relation(fields: [wbs_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  boq_item BOQItem?        @relation(fields: [boq_item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("progress_invoice_items")
  @@schema("auth")
}

// ═══════════════════════════════════════════════════════════════════════════════
// WEEK 6 PHASE 1: PROJECT INITIATION + ENGINEERING PLANNING
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Project Plan (Master baseline plan header) ───────────────────────────────
model ProjectPlan {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id        String    @db.Uuid
  project_id        String    @db.Uuid
  plan_no           String    @unique @db.VarChar(100)
  title             String    @db.VarChar(500)
  plan_type         String    @default("BASELINE") @db.VarChar(50) // BASELINE | REVISED | APPROVED
  status            String    @default("draft") @db.VarChar(30) // draft | submitted | in_approval | approved | rejected
  version           Int       @default(1)
  // Baseline schedule summary
  baseline_start    DateTime? @db.Date
  baseline_end      DateTime? @db.Date
  baseline_duration Int? // working days
  contract_value    Decimal?  @db.Decimal
  // Approval gate
  approved_by       String?   @db.Uuid
  approved_at       DateTime? @db.Timestamp(6)
  approval_remarks  String?
  notes             String?
  created_by        String    @db.Uuid
  created_at        DateTime  @default(now()) @db.Timestamp(6)
  updated_at        DateTime  @updatedAt @db.Timestamp(6)
  deleted_at        DateTime? @db.Timestamp(6)

  company  Company @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project  Project @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  creator  User    @relation("PlanCreator", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approver User?   @relation("PlanApprover", fields: [approved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  boq_validations   BOQValidation[]
  schedules         ProjectSchedule[]
  procurement_items ProcurementPlanItem[]
  resource_plans    ResourcePlan[]
  allocations       ResourceAllocation[]

  @@index([company_id, project_id, status])
  @@map("project_plans")
  @@schema("auth")
}

// ─── BOQ Validation (BOQ ↔ WBS ↔ CostCode linkage validator) ─────────────────
model BOQValidation {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id        String    @db.Uuid
  project_id        String    @db.Uuid
  plan_id           String?   @db.Uuid
  boq_item_id       String    @db.Uuid
  wbs_id            String    @db.Uuid
  cost_code_id      String?   @db.Uuid
  // Validation flags
  is_wbs_linked     Boolean   @default(false)
  is_cost_coded     Boolean   @default(false)
  is_rate_valid     Boolean   @default(false) // unit_rate > 0
  is_complete       Boolean   @default(false) // all flags TRUE
  validation_errors Json? // string[]
  validated_by      String?   @db.Uuid
  validated_at      DateTime? @db.Timestamp(6)
  created_at        DateTime  @default(now()) @db.Timestamp(6)
  updated_at        DateTime  @updatedAt @db.Timestamp(6)

  company   Company      @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project   Project      @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  plan      ProjectPlan? @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  boq_item  BOQItem      @relation(fields: [boq_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wbs       WBS          @relation(fields: [wbs_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cost_code CostCode?    @relation(fields: [cost_code_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  validator User?        @relation("BOQValidator", fields: [validated_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  allocations ResourceAllocation[]

  @@unique([boq_item_id, plan_id])
  @@index([project_id, is_complete])
  @@map("boq_validations")
  @@schema("auth")
}

// ─── Project Schedule (Baseline Gantt per WBS) ───────────────────────────────
model ProjectSchedule {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id        String    @db.Uuid
  project_id        String    @db.Uuid
  plan_id           String?   @db.Uuid
  wbs_id            String    @db.Uuid
  sequence_no       Int       @default(0)
  baseline_start    DateTime  @db.Date
  baseline_end      DateTime  @db.Date
  baseline_duration Int? // working days
  actual_start      DateTime? @db.Date
  actual_end        DateTime? @db.Date
  float_days        Int?      @default(0)
  is_critical       Boolean   @default(false)
  dependencies      Json? // [{wbs_id, type:'FS|SS|FF|SF', lag:0}]
  notes             String?
  created_by        String    @db.Uuid
  created_at        DateTime  @default(now()) @db.Timestamp(6)
  updated_at        DateTime  @updatedAt @db.Timestamp(6)

  company Company      @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project Project      @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  plan    ProjectPlan? @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wbs     WBS          @relation(fields: [wbs_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator User         @relation("ScheduleCreator", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([plan_id, wbs_id])
  @@index([project_id, is_critical])
  @@map("project_schedules")
  @@schema("auth")
}

// ─── Procurement Plan Item (Long-lead + supply chain) ────────────────────────
model ProcurementPlanItem {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id       String    @db.Uuid
  project_id       String    @db.Uuid
  plan_id          String?   @db.Uuid
  wbs_id           String?   @db.Uuid
  item_description String    @db.VarChar(500)
  category         String?   @db.VarChar(100) // MATERIAL | EQUIPMENT | SUBCONTRACT | SERVICE
  estimated_cost   Decimal?  @db.Decimal
  required_date    DateTime? @db.Date
  lead_time_days   Int?      @default(0)
  is_long_lead     Boolean   @default(false) // KEY: triggers early procurement alert
  vendor_id        String?   @db.Uuid
  pr_required_by   DateTime? @db.Date // required_date - lead_time
  status           String    @default("planned") @db.VarChar(30) // planned|pr_raised|po_issued|delivered
  linked_pr_id     String?   @db.Uuid
  linked_po_id     String?   @db.Uuid
  notes            String?
  attachments      Json?
  created_by       String    @db.Uuid
  created_at       DateTime  @default(now()) @db.Timestamp(6)
  updated_at       DateTime  @updatedAt @db.Timestamp(6)

  company   Company              @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project   Project              @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  plan      ProjectPlan?         @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wbs       WBS?                 @relation(fields: [wbs_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendor    Vendor?              @relation(fields: [vendor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  linked_pr PurchaseRequisition? @relation(fields: [linked_pr_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  linked_po PurchaseOrder?       @relation(fields: [linked_po_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator   User                 @relation("ProcPlanCreator", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  allocations ResourceAllocation[]

  @@index([project_id, is_long_lead])
  @@index([project_id, status])
  @@map("procurement_plan_items")
  @@schema("auth")
}

// ─── Resource Plan (Manpower + Equipment baseline per WBS) ───────────────────
model ResourcePlan {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id      String    @db.Uuid
  project_id      String    @db.Uuid
  plan_id         String?   @db.Uuid
  wbs_id          String?   @db.Uuid
  resource_type   String    @db.VarChar(20) // MANPOWER | EQUIPMENT
  // Manpower
  trade           String?   @db.VarChar(100)
  headcount       Int?      @default(1)
  daily_rate      Decimal?  @db.Decimal
  planned_days    Int?      @default(0)
  // Equipment
  equipment_type  String?   @db.VarChar(100)
  equipment_count Int?      @default(1)
  hire_rate       Decimal?  @db.Decimal
  planned_hours   Decimal?  @db.Decimal
  // Timing
  planned_start   DateTime? @db.Date
  planned_end     DateTime? @db.Date
  notes           String?
  created_by      String    @db.Uuid
  created_at      DateTime  @default(now()) @db.Timestamp(6)
  updated_at      DateTime  @updatedAt @db.Timestamp(6)

  company Company      @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project Project      @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  plan    ProjectPlan? @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wbs     WBS?         @relation(fields: [wbs_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator User         @relation("ResourcePlanCreator", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  allocations ResourceAllocation[]

  @@index([project_id, resource_type])
  @@index([plan_id])
  @@map("resource_plans")
  @@schema("auth")
}

// ═══════════════════════════════════════════════════════════════════════════════
// WEEK 6 PHASE 2: RESOURCE ALLOCATION + EXECUTION MODULES
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Resource Allocation (Central Execution Hub) ─────────────────────────────
model ResourceAllocation {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id      String  @db.Uuid
  project_id      String  @db.Uuid
  plan_id         String? @db.Uuid
  department_id   String? @db.Uuid
  allocation_type String  @db.VarChar(50) // MATERIAL | LABOR | EQUIPMENT | SERVICE
  status          String  @default("pending") @db.VarChar(30) // pending | assigned | pr_created | complete | locked

  // Generic Traceability
  source_type String @db.VarChar(50) // BOQ_VALIDATION | PROCUREMENT_PLAN | RESOURCE_PLAN
  source_id   String @db.Uuid // Specific record ID from source

  // Explicit Traceability (User requested explicit FKs)
  boq_validation_id        String? @db.Uuid
  procurement_plan_item_id String? @db.Uuid
  resource_plan_id         String? @db.Uuid
  boq_item_id              String? @db.Uuid
  wbs_id                   String? @db.Uuid
  cost_code_id             String? @db.Uuid

  // Quantities & Integrity
  planned_qty   Decimal @default(0) @db.Decimal
  requested_qty Decimal @default(0) @db.Decimal
  fulfilled_qty Decimal @default(0) @db.Decimal
  // remaining_qty is auto-calculated in business logic/views (planned - requested)

  required_date DateTime? @db.Date
  notes         String?
  is_locked     Boolean   @default(false)

  created_by String    @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime  @updatedAt @db.Timestamp(6)
  deleted_at DateTime? @db.Timestamp(6)

  // Relations
  company    Company      @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project    Project      @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  plan       ProjectPlan? @relation(fields: [plan_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  department Department?  @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator    User         @relation("AllocationCreator", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  status_logs                 ResourceAllocationStatusLog[]
  assignment_logs             AllocationAssignmentLog[]
  logistics_links             LogisticsAllocation[]
  inventory_planning_requests InventoryPlanningRequest[]

  boq_validation        BOQValidation?       @relation(fields: [boq_validation_id], references: [id])
  procurement_plan_item ProcurementPlanItem? @relation(fields: [procurement_plan_item_id], references: [id])
  resource_plan         ResourcePlan?        @relation(fields: [resource_plan_id], references: [id])

  wbs   WBS?    @relation(fields: [wBSId], references: [id])
  wBSId String? @db.Uuid

  @@index([company_id, project_id])
  @@index([status])
  @@index([required_date])
  @@index([source_id])
  @@map("resource_allocations")
  @@schema("auth")
}

model ResourceAllocationStatusLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  allocation_id String   @db.Uuid
  status_from   String   @db.VarChar(30)
  status_to     String   @db.VarChar(30)
  remarks       String?
  created_by    String   @db.Uuid
  created_at    DateTime @default(now()) @db.Timestamp(6)

  allocation ResourceAllocation @relation(fields: [allocation_id], references: [id], onDelete: Cascade)
  actor      User               @relation(fields: [created_by], references: [id])

  @@map("resource_allocation_status_logs")
  @@schema("auth")
}

model AllocationAssignmentLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  allocation_id   String   @db.Uuid
  department_from String?  @db.Uuid
  department_to   String   @db.Uuid
  remarks         String?
  created_by      String   @db.Uuid
  created_at      DateTime @default(now()) @db.Timestamp(6)

  allocation ResourceAllocation @relation(fields: [allocation_id], references: [id], onDelete: Cascade)

  @@map("allocation_assignment_logs")
  @@schema("auth")
}

// ─── Service Request (Subcontracting Workflow) ──────────────────────────────
model ServiceRequest {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  request_no   String  @unique @db.VarChar(100)
  company_id   String  @db.Uuid
  project_id   String  @db.Uuid
  wbs_id       String? @db.Uuid
  cost_code_id String? @db.Uuid

  description    String    @db.VarChar(1000)
  service_type   String?   @db.VarChar(100)
  estimated_cost Decimal?  @db.Decimal
  required_date  DateTime? @db.Date

  status            String  @default("draft") @db.VarChar(30) // draft | submitted | under_review | approved | rejected | converted | cancelled
  conversion_status String  @default("NONE") @db.VarChar(20) // NONE | PARTIAL | FULL
  converted_pr_id   String? @db.Uuid // Link to PurchaseRequisition

  created_by String    @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime  @updatedAt @db.Timestamp(6)
  deleted_at DateTime? @db.Timestamp(6)

  company   Company              @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project   Project              @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wbs       WBS?                 @relation(fields: [wbs_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cost_code CostCode?            @relation(fields: [cost_code_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator   User                 @relation("ServiceReqCreator", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  linked_pr PurchaseRequisition? @relation(fields: [converted_pr_id], references: [id])

  status_logs ServiceRequestStatusLog[]

  @@index([company_id, project_id])
  @@index([status])
  @@index([required_date])
  @@map("service_requests")
  @@schema("auth")
}

model ServiceRequestStatusLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  request_id  String   @db.Uuid
  status_from String   @db.VarChar(30)
  status_to   String   @db.VarChar(30)
  remarks     String?
  created_by  String   @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamp(6)

  request ServiceRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)

  @@map("service_request_status_logs")
  @@schema("auth")
}

// ─── Inventory Planning (Store Buffer Requests) ──────────────────────────────
model InventoryPlanningRequest {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id    String  @db.Uuid
  project_id    String  @db.Uuid
  wbs_id        String? @db.Uuid
  allocation_id String? @db.Uuid
  item_id       String  @db.Uuid
  store_id      String? @db.Uuid

  quantity           Decimal   @db.Decimal
  required_date      DateTime? @db.Date
  reservation_status String    @default("PENDING") @db.VarChar(20) // PENDING | RESERVED | ISSUED | CANCELLED
  status             String    @default("draft") @db.VarChar(30)

  created_by String    @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime  @updatedAt @db.Timestamp(6)
  deleted_at DateTime? @db.Timestamp(6)

  company    Company             @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project    Project             @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  item       Item                @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  store      Store?              @relation(fields: [store_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  allocation ResourceAllocation? @relation(fields: [allocation_id], references: [id])
  wbs        WBS?                @relation(fields: [wBSId], references: [id])
  wBSId      String?             @db.Uuid

  @@index([company_id, project_id, reservation_status])
  @@map("inventory_planning_requests")
  @@schema("auth")
}

// ─── Logistics Request (Mobilization & Site Transport) ────────────────────────
model LogisticsRequest {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id String @db.Uuid
  project_id String @db.Uuid

  request_type  String    @db.VarChar(50) // MOBILIZATION | TRANSPORT | MATERIAL_SHIFTING
  description   String?
  origin        String?   @db.VarChar(255)
  destination   String?   @db.VarChar(255)
  required_date DateTime? @db.Date
  status        String    @default("draft") @db.VarChar(30)

  created_by String    @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime  @updatedAt @db.Timestamp(6)
  deleted_at DateTime? @db.Timestamp(6)

  company Company @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  allocations  LogisticsAllocation[]
  department   Department?           @relation(fields: [departmentId], references: [id])
  departmentId String?               @db.Uuid

  @@index([company_id, project_id, status])
  @@map("logistics_requests")
  @@schema("auth")
}

model LogisticsAllocation {
  id                   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  logistics_request_id String @db.Uuid
  allocation_id        String @db.Uuid

  request    LogisticsRequest   @relation(fields: [logistics_request_id], references: [id], onDelete: Cascade)
  allocation ResourceAllocation @relation(fields: [allocation_id], references: [id], onDelete: Cascade)

  @@unique([logistics_request_id, allocation_id])
  @@map("logistics_allocations")
  @@schema("auth")
}

// ─── Phase 3: Procurement & Mobilization ──────────────────────────────────────
model DeliveryTracking {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id    String    @db.Uuid
  project_id    String?   @db.Uuid
  po_id         String    @db.Uuid
  item_id       String?   @db.Uuid
  expected_date DateTime  @db.Date
  actual_date   DateTime? @db.Date
  status        String    @default("pending") @db.VarChar(50) // pending | transit | delivered | delayed
  remarks       String?
  created_at    DateTime  @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @db.Timestamp(6)

  company Company       @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project Project?      @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  po      PurchaseOrder @relation(fields: [po_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  item    Item?         @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("delivery_tracking")
  @@schema("auth")
}

model MobilizationLog {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id    String    @db.Uuid
  project_id    String?   @db.Uuid
  resource_type String    @db.VarChar(50) // MANPOWER | EQUIPMENT
  resource_name String    @db.VarChar(200)
  planned_date  DateTime  @db.Date
  actual_date   DateTime? @db.Date
  status        String    @default("pending") @db.VarChar(50) // pending | mobilized | demobilized
  remarks       String?
  created_at    DateTime  @default(now()) @db.Timestamp(6)
  updated_at    DateTime  @updatedAt @db.Timestamp(6)

  company Company  @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project Project? @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("mobilization_logs")
  @@schema("auth")
}

// ─── Timesheet (Phase 4 — Crew Clock-In / Clock-Out) ─────────────────────────
model Timesheet {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id    String    @db.Uuid
  project_id    String    @db.Uuid
  dpr_id        String?   @db.Uuid
  employee_id   String?   @db.Uuid
  resource_name String?   @db.VarChar(200) // for daily labour without employee record
  resource_type String    @default("labor") @db.VarChar(30) // labor | equipment
  check_in_at   DateTime  @db.Timestamp(6)
  check_out_at  DateTime? @db.Timestamp(6)
  total_hours   Decimal?  @db.Decimal(8, 2)
  clocked_by_id String?   @db.Uuid // Site Engineer who clocked them in
  notes         String?
  created_at    DateTime  @default(now()) @db.Timestamp(6)
  updated_at    DateTime  @updatedAt @db.Timestamp(6)

  company    Company   @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project    Project   @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employee   Employee? @relation(fields: [employee_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  clocked_by User?     @relation("TimesheetClockedBy", fields: [clocked_by_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([company_id, project_id])
  @@index([project_id, check_in_at])
  @@map("timesheets")
  @@schema("auth")
}

model ProjectStatusLog {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id   String    @db.Uuid
  old_status   String?   @db.VarChar(30)
  new_status   String    @db.VarChar(30)
  reason       String?   @db.Text
  updated_by   String?   @db.Uuid
  created_at   DateTime  @default(now()) @db.Timestamp(6)

  project    Project @relation(fields: [project_id], references: [id])
  updater    User?   @relation("StatusUpdater", fields: [updated_by], references: [id])

  @@map("project_status_logs")
  @@schema("auth")
}

model PunchListItem {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id   String    @db.Uuid
  project_id   String    @db.Uuid
  wbs_id       String?   @db.Uuid
  item_no      String    @unique @db.VarChar(100)
  title        String    @db.VarChar(300)
  description  String?
  location     String?   @db.VarChar(200)
  category     String?   @db.VarChar(100)
  severity     String?   @default("medium") @db.VarChar(20)
  status       String    @default("open") @db.VarChar(30)
  raised_by    String    @db.Uuid
  assigned_to  String?   @db.Uuid
  target_date  DateTime? @db.Date
  verified_at  DateTime? @db.Timestamp(6)
  attachments  Json?
  created_at   DateTime  @default(now()) @db.Timestamp(6)
  updated_at   DateTime  @updatedAt @db.Timestamp(6)

  company  Company @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project  Project @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wbs      WBS?    @relation(fields: [wbs_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  raiser   User    @relation("PunchRaiser", fields: [raised_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignee User?   @relation("PunchAssignee", fields: [assigned_to], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([company_id, project_id, status])
  @@map("punch_list_items")
  @@schema("auth")
}

model ProjectClosure {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id        String    @db.Uuid
  project_id        String    @unique @db.Uuid
  request_no        String    @unique @db.VarChar(100)
  status            String    @default("draft") @db.VarChar(30)
  prepared_by       String    @db.Uuid
  handover_date     DateTime? @db.Date
  completion_notes  String?
  attachments       Json?
  total_snags       Int       @default(0)
  cleared_snags     Int       @default(0)
  wbs_completion    Decimal   @default(0) @db.Decimal
  created_at        DateTime  @default(now()) @db.Timestamp(6)
  updated_at        DateTime  @updatedAt @db.Timestamp(6)
  approved_at       DateTime? @db.Timestamp(6)

  company  Company @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project  Project @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  preparer User    @relation("ClosurePreparer", fields: [prepared_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([company_id, project_id])
  @@map("project_closures")
  @@schema("auth")
}
