// ─── Master Data (Week 3) ────────────────────────────────────────────────────

model WBS {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id   String?   @db.Uuid
  wbs_code     String?   @db.VarChar(50)
  name         String    @db.VarChar(200)
  parent_id    String?   @db.Uuid
  start_date   DateTime? @db.Date
  end_date     DateTime? @db.Date
  progress_pct Decimal?  @default(0) @db.Decimal
  status       String?   @default("active") @db.VarChar(50)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  updated_at   DateTime? @db.Timestamp(6)
  deleted_at   DateTime? @db.Timestamp(6)

  // Week 6: Planning & Execution fields
  planned_qty   Decimal?  @default(0) @db.Decimal // BOQ planned quantity
  actual_qty    Decimal?  @default(0) @db.Decimal // Cumulative actual from DPRs
  unit          String?   @db.VarChar(50)
  planned_start DateTime? @db.Date
  planned_end   DateTime? @db.Date
  actual_start  DateTime? @db.Date
  actual_end    DateTime? @db.Date
  planned_cost  Decimal?  @default(0) @db.Decimal // From BOQ/budget
  weight_pct    Decimal?  @default(0) @db.Decimal // % weight in project (all roots sum to 100)

  project    Project?   @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  parent     WBS?       @relation("WBSHierarchy", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children   WBS[]      @relation("WBSHierarchy")
  cost_codes CostCode[]

  purchase_requisitions PurchaseRequisition[]
  petty_cash_requests   PettyCashRequest[]
  material_issues       MaterialIssue[]

  // Week 6 relations
  boq_items      BOQItem[]
  dpr_items      DPRItem[]
  resource_logs  ResourceLog[]
  hindrance_logs HindranceLog[]
  delay_records  DelayRecord[]
  inspections    Inspection[]
  ncrs           NCR[]
  vo_items       VOItem[]
  invoice_items  ProgressInvoiceItem[]
  itp_plans      ITPPlan[]
  risk_registers RiskRegister[]
  safety_jsas    SafetyJSA[]

  // Week 6 Initiation Relations
  boq_validations BOQValidation[]
   meeting_logs    MeetingLog[]
  rfis            RFI[]
  submittals      Submittal[]
  schedules       ProjectSchedule[]
  proc_plan_items ProcurementPlanItem[]
  resource_plans  ResourcePlan[]

  // Week 6 Phase 2
  allocations        ResourceAllocation[]
  service_requests   ServiceRequest[]
  inventory_requests InventoryPlanningRequest[]
  execution_tasks    ExecutionTask[]
  cost_trackings     CostTracking[]
  punch_list_items   PunchListItem[]

  @@map("wbs")
  @@schema("auth")
}

model CostCode {
