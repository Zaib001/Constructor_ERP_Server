generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["audit", "auth"]
}

// ─── Company (Multi-Company Structure) ──────────────────────────────────────
model Company {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String             @unique @db.VarChar(50)
  name                String             @db.VarChar(200)
  address             String?
  phone               String?            @db.VarChar(30)
  email               String?            @db.VarChar(150)
  is_active           Boolean?           @default(true)
  created_at          DateTime?          @default(now()) @db.Timestamp(6)
  updated_at          DateTime?          @db.Timestamp(6)
  deleted_at          DateTime?          @db.Timestamp(6)
  departments         Department[]
  users               User[]
  projects            Project[]
  approval_matrices   ApprovalMatrix[]
  system_settings     SystemSetting[]
  profit_share_rules  ProfitShareRule[]
  vendors             Vendor[]
  purchase_orders     PurchaseOrder[]
  payrolls            Payroll[]
  quotations          Quotation[]
  expenses            Expense[]
  registration_number String?            @db.VarChar(50)
  vat_number          String?            @db.VarChar(50)
  company_documents   CompanyDocument[]
  items               Item[]
  facility_documents  FacilityDocument[]
  // purchase_requests   PurchaseRequest[]

  approval_requests ApprovalRequest[]
  employees         Employee[]
  vehicles          Vehicle[]
  equipment         Equipment[]

  purchase_requisitions PurchaseRequisition[]
  petty_cash_requests   PettyCashRequest[]

  petrol_expenses  PetrolExpense[]
  inventory_stocks InventoryStock[]
  inventory_stores Store[]
  inventory_grns   GoodsReceiptNote[]
  stock_ledger     StockLedger[]
  material_issues  MaterialIssue[]
  excessMaterials  ExcessMaterial[]

  // Week 6 relations
  boq_items      BOQItem[]
  dprs           DPR[]
  resource_logs  ResourceLog[]
  hindrance_logs HindranceLog[]

  progress_invoices ProgressInvoice[]

  // Week 6 Initiation
  project_plans          ProjectPlan[]
  boq_validations        BOQValidation[]
  project_schedules      ProjectSchedule[]
  procurement_plan_items ProcurementPlanItem[]
  resource_plans         ResourcePlan[]

  // Week 6 Phase 2
  allocations        ResourceAllocation[]
  service_requests   ServiceRequest[]
  inventory_requests InventoryPlanningRequest[]
  logistics_requests LogisticsRequest[]
  riskRegisters      RiskRegister[]
  delayRecords       DelayRecord[]
  variationOrders    VariationOrder[]
  rfis               RFI[]
  submittals         Submittal[]
  meetingLogs        MeetingLog[]
  inspections        Inspection[]
  ncrs               NCR[]
  safetyIncidents    SafetyIncident[]
  hseinductions      HSEInduction[]
  deliveryTrackings  DeliveryTracking[]
  mobilizationLogs   MobilizationLog[]
  execution_tasks    ExecutionTask[]
  timesheets         Timesheet[]
  itp_plans          ITPPlan[]
  safety_logs        SafetyLog[]
  safety_jsas        SafetyJSA[]
  claims             Claim[]
  billing_cycles     BillingCycle[]
  cost_trackings     CostTracking[]
  involved_incidents SafetyIncident[] @relation("IncidentInvolvedCompany")
  involved_inductions HSEInduction[]   @relation("InductionInvolvedCompany")
  punch_list_items    PunchListItem[]
  project_closures    ProjectClosure[]

  @@map("companies")
  @@schema("auth")
}

model Role {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String           @db.VarChar(100)
  code              String?          @unique @db.VarChar(50)
  description       String?
  is_system_role    Boolean?         @default(false)
  is_active         Boolean?         @default(true)
  created_by        String?          @db.Uuid
  created_at        DateTime?        @default(now()) @db.Timestamp(6)
  updated_at        DateTime?        @db.Timestamp(6)
  deleted_at        DateTime?        @db.Timestamp(6)
  approval_matrices ApprovalMatrix[]
  approval_steps    ApprovalStep[]
  role_permissions  RolePermission[]
  users             User[]

  @@map("roles")
  @@schema("auth")
}

model Department {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code               String               @unique @db.VarChar(50)
  name               String               @db.VarChar(150)
  description        String?
  is_active          Boolean?             @default(true)
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  company_id         String?              @db.Uuid
  head_id            String?              @db.Uuid
  deleted_at         DateTime?            @db.Timestamp(6)
  company            Company?             @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approval_matrices  ApprovalMatrix[]
  approval_requests  ApprovalRequest[]
  users              User[]
  profit_share_rules ProfitShareRule[]
  purchase_orders    PurchaseOrder[]
  payrolls           Payroll[]
  quotations         Quotation[]
  expenses           Expense[]
  vendors            Vendor[]
  employees          Employee[]
  vehicles           Vehicle[]
  logistics_requests LogisticsRequest[]
  allocations        ResourceAllocation[]
  equipment          Equipment[]

  @@map("departments")
  @@schema("auth")
}

model User {
  id                   String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employee_code        String?           @db.VarChar(50)
  name                 String            @db.VarChar(150)
  email                String            @unique @db.VarChar(150)
  phone                String?           @db.VarChar(30)
  password_hash        String
  role_id              String?           @db.Uuid
  designation          String?           @db.VarChar(100)
  manager_id           String?           @db.Uuid
  is_active            Boolean?          @default(true)
  is_locked            Boolean?          @default(false)
  login_attempts       Int?              @default(0)
  last_login_at        DateTime?         @db.Timestamp(6)
  last_password_change DateTime?         @db.Timestamp(6)
  created_by           String?           @db.Uuid
  created_at           DateTime?         @default(now()) @db.Timestamp(6)
  updated_at           DateTime?         @db.Timestamp(6)
  deleted_at           DateTime?         @db.Timestamp(6)
  department_id        String?           @db.Uuid
  company_id           String?           @db.Uuid
  password_resets      PasswordReset[]
  user_projects        UserProject[]
  user_sessions        UserSession[]
  departments          Department?       @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  roles                Role?             @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  company              Company?          @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  created_vendors      Vendor[]          @relation("VendorCreator")
  created_pos          PurchaseOrder[]   @relation("POCreator")
  created_payrolls     Payroll[]         @relation("PayrollCreator")
  created_quotations   Quotation[]       @relation("QuotationCreator")
  created_expenses     Expense[]         @relation("ExpenseCreator")
  created_progress     ProjectProgress[] @relation("ProgressCreator")
  initiated_requests   ApprovalRequest[] @relation("RequestInitiator")

  requested_prs        PurchaseRequisition[] @relation("PRRequester")
  approved_prs         PRApproval[]          @relation("PRApprover")
  created_rfqs         RFQ[]                 @relation("RFQCreator")
  compared_rfqs        ComparisonEngine[]    @relation("RFQComparator")
  requested_petty_cash PettyCashRequest[]    @relation("PettyCashRequester")
  approved_petty_cash  PettyCashRequest[]    @relation("PettyCashApprover")
  verified_petty_cash  PettyCashExpense[]    @relation("PettyCashVerifier")

  created_petrol_expenses  PetrolExpense[] @relation("PetrolCreator")
  verified_petrol_expenses PetrolExpense[] @relation("PetrolVerifier")

  received_grns    GoodsReceiptNote[] @relation("GRNReceiver")
  issued_materials MaterialIssue[]    @relation("IssueIssuer")
  ledger_entries   StockLedger[]      @relation("LedgerCreator")

  // Week 6 relations
  created_dprs       DPR[]            @relation("DPRCreator")
  submitted_dprs     DPR[]            @relation("DPRSubmitter")
  reviewed_dprs      DPR[]            @relation("DPRReviewer")
  resource_logs      ResourceLog[]    @relation("ResourceCreator")
  created_risks      RiskRegister[]   @relation("RiskCreator")
  owned_risks        RiskRegister[]   @relation("RiskOwner")
  created_delays     DelayRecord[]    @relation("DelayCreator")
  tasks_assigned     ExecutionTask[]  @relation("TaskAssignedTo")
  tasks_created      ExecutionTask[]  @relation("TaskAssignedBy")
  clocked_timesheets Timesheet[]      @relation("TimesheetClockedBy")
  created_vos        VariationOrder[] @relation("VOCreator")
  approved_vos       VariationOrder[] @relation("VOApprover")
  raised_rfis        RFI[]            @relation("RFIRaiser")
  raised_ncrs        NCR[]            @relation("NCRRaiser")
  created_incidents  SafetyIncident[] @relation("IncidentCreator")
  created_hindrances HindranceLog[]   @relation("HindranceCreator")
  created_boq        BOQItem[]        @relation("BOQCreator")

  // Week 6 Initiation relations
  created_plans      ProjectPlan[]         @relation("PlanCreator")
  approved_plans     ProjectPlan[]         @relation("PlanApprover")
  boq_validations    BOQValidation[]       @relation("BOQValidator")
  created_schedules  ProjectSchedule[]     @relation("ScheduleCreator")
  created_proc_plans ProcurementPlanItem[] @relation("ProcPlanCreator")
  created_res_plans  ResourcePlan[]        @relation("ResourcePlanCreator")

  // Week 6 Phase 2
  created_allocations    ResourceAllocation[]          @relation("AllocationCreator")
  created_service_reqs   ServiceRequest[]              @relation("ServiceReqCreator")
  allocation_status_logs ResourceAllocationStatusLog[]
  created_claims         Claim[]                       @relation("ClaimCreator")
  safety_logs_observed   SafetyLog[]                   @relation("SafetyObserver")
  jsas_created           SafetyJSA[]                   @relation("JSACreator")
  jsas_approved          SafetyJSA[]                   @relation("JSAApprover")
  updated_status_logs    ProjectStatusLog[]          @relation("StatusUpdater")
  raised_punches         PunchListItem[]               @relation("PunchRaiser")
  assigned_punches       PunchListItem[]               @relation("PunchAssignee")
  prepared_closures      ProjectClosure[]              @relation("ClosurePreparer")

  @@map("users")
  @@schema("auth")
}

model Permission {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String           @unique @db.VarChar(100)
  module           String?          @db.VarChar(50)
  description      String?
  created_at       DateTime?        @default(now()) @db.Timestamp(6)
  role_permissions RolePermission[]

  @@map("permissions")
  @@schema("auth")
}

model RolePermission {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_id       String?     @db.Uuid
  permission_id String?     @db.Uuid
  created_at    DateTime?   @default(now()) @db.Timestamp(6)
  permissions   Permission? @relation(fields: [permission_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  roles         Role?       @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("role_permissions")
  @@schema("auth")
}

model Project {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code               String?           @unique @db.VarChar(50)
  name               String            @db.VarChar(200)
  description        String?
  status             String?           @default("active") @db.VarChar(20)
  start_date         DateTime?         @db.Timestamp(6)
  end_date           DateTime?         @db.Timestamp(6)
  created_at         DateTime?         @default(now()) @db.Timestamp(6)
  updated_at         DateTime?         @db.Timestamp(6)
  deleted_at         DateTime?         @db.Timestamp(6)
  company_id         String?           @db.Uuid
  budget             Decimal?          @db.Decimal
  revenue            Decimal?          @db.Decimal
  cost               Decimal?          @db.Decimal
  advance_payment_amount Decimal?      @default(0) @db.Decimal
  advance_recovery_pct   Decimal?      @default(10) @db.Decimal
  retention_pct          Decimal?      @default(10) @db.Decimal
  company            Company?          @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approval_matrices  ApprovalMatrix[]
  approval_requests  ApprovalRequest[]
  user_projects      UserProject[]
  profit_share_rules ProfitShareRule[]
  purchase_orders    PurchaseOrder[]
  quotations         Quotation[]
  expenses           Expense[]
  progress           ProjectProgress[]
  location           String?
  client             String?
  contract_value     Decimal?          @db.Decimal // Week 6: signed contract amount
  current_contract_value Decimal?       @db.Decimal // Revised after VOs/Claims
  forecast_end_date  DateTime?         @db.Timestamp(6) // Recalculated after Delays
  wbs                WBS[]
  employees          Employee[]
  vehicles           Vehicle[]
  equipment          Equipment[]
  // purchase_requests   PurchaseRequest[]

  purchase_requisitions PurchaseRequisition[]
  petty_cash_requests   PettyCashRequest[]

  petrol_expenses PetrolExpense[]
  material_issues MaterialIssue[]

  // Week 6 relations
  boq_items      BOQItem[]
  dprs           DPR[]
  resource_logs  ResourceLog[]
  hindrance_logs HindranceLog[]

  progress_invoices ProgressInvoice[]
  itp_plans         ITPPlan[]

  // Week 6 Initiation
  project_plans          ProjectPlan[]
  boq_validations        BOQValidation[]
  project_schedules      ProjectSchedule[]
  procurement_plan_items ProcurementPlanItem[]
  resource_plans         ResourcePlan[]

  // Week 6 Phase 2
  allocations        ResourceAllocation[]
  service_requests   ServiceRequest[]
  inventory_requests InventoryPlanningRequest[]
  logistics_requests LogisticsRequest[]

  risk_registers    RiskRegister[]
  delay_records     DelayRecord[]
  variation_orders  VariationOrder[]
  rfis              RFI[]
  submittals        Submittal[]
  meeting_logs      MeetingLog[]
  inspections       Inspection[]
  ncrs              NCR[]
  safety_incidents  SafetyIncident[]
  hse_inductions    HSEInduction[]
  deliveryTrackings DeliveryTracking[]
  mobilizationLogs  MobilizationLog[]
  execution_tasks   ExecutionTask[]
  timesheets        Timesheet[]
  safety_logs       SafetyLog[]
  safety_jsas       SafetyJSA[]
  claims            Claim[]
  billing_cycles    BillingCycle[]
  cost_trackings    CostTracking[]
  status_logs       ProjectStatusLog[]
  punch_list_items  PunchListItem[]
  closure           ProjectClosure?

  @@map("projects")
  @@schema("auth")
}

model UserProject {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?   @db.Uuid
  project_id  String?   @db.Uuid
  access_type String?   @db.VarChar(50)
  assigned_by String?   @db.Uuid
  assigned_at DateTime? @default(now()) @db.Timestamp(6)
  revoked_at  DateTime? @db.Timestamp(6)
  projects    Project?  @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users       User?     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("user_projects")
  @@schema("auth")
}

model UserSession {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?   @db.Uuid
  jwt_token   String?
  ip_address  String?
  device_info String?
  login_time  DateTime? @default(now()) @db.Timestamp(6)
  logout_time DateTime? @db.Timestamp(6)
  is_active   Boolean?  @default(true)
  users       User?     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([jwt_token])
  @@index([user_id, is_active])
  @@map("user_sessions")
  @@schema("auth")
}

model PasswordReset {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?   @db.Uuid
  reset_token String?
  expires_at  DateTime? @db.Timestamp(6)
  used        Boolean?  @default(false)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       User?     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("password_resets")
  @@schema("auth")
}

model ApprovalMatrix {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  doc_type         String      @db.VarChar(50)
  project_id       String?     @db.Uuid
  min_amount       Decimal?    @db.Decimal
  max_amount       Decimal?    @db.Decimal
  role_id          String?     @db.Uuid
  step_order       Int?
  is_parallel      Boolean?    @default(false)
  is_mandatory     Boolean?    @default(true)
  escalation_hours Int?
  created_at       DateTime?   @default(now()) @db.Timestamp(6)
  updated_at       DateTime?   @db.Timestamp(6)
  deleted_at       DateTime?   @db.Timestamp(6)
  department_id    String?     @db.Uuid
  company_id       String?     @db.Uuid
  company          Company?    @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  departments      Department? @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects         Project?    @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  roles            Role?       @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("approval_matrices")
  @@schema("auth")
}

model ApprovalRequest {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  doc_type       String?               @db.VarChar(50)
  doc_id         String?               @db.VarChar(100)
  project_id     String?               @db.Uuid
  requested_by   String?               @db.Uuid
  current_status String?               @db.VarChar(50)
  total_steps    Int?
  current_step   Int?
  amount         Decimal?              @db.Decimal
  is_completed   Boolean?              @default(false)
  created_at     DateTime?             @default(now()) @db.Timestamp(6)
  completed_at   DateTime?             @db.Timestamp(6)
  deleted_at     DateTime?             @db.Timestamp(6)
  attachment_url String?
  department_id  String?               @db.Uuid
  company_id     String?               @db.Uuid
  items          ApprovalRequestItem[]
  department     Department?           @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project        Project?              @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  company        Company?              @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  requestedByRel User?                 @relation("RequestInitiator", fields: [requested_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approval_steps ApprovalStep[]

  @@map("approval_requests")
  @@schema("auth")
}

model ApprovalRequestItem {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  approval_request_id String?          @db.Uuid
  item_name           String           @db.VarChar(200)
  quantity            Decimal?         @db.Decimal
  unit                String?          @db.VarChar(50)
  unit_price          Decimal?         @db.Decimal
  total_price         Decimal?         @db.Decimal
  remarks             String?
  created_at          DateTime?        @default(now()) @db.Timestamp(6)
  approval_requests   ApprovalRequest? @relation(fields: [approval_request_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("approval_request_items")
  @@schema("auth")
}

model ApprovalStep {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  approval_request_id String?          @db.Uuid
  step_order          Int?
  role_id             String?          @db.Uuid
  approver_user       String?          @db.Uuid
  status              String?          @db.VarChar(50)
  action              String?          @db.VarChar(50)
  remarks             String?
  approved_at         DateTime?        @db.Timestamp(6)
  deleted_at          DateTime?        @db.Timestamp(6)
  escalated           Boolean?         @default(false)
  escalated_to        String?          @db.Uuid
  approval_requests   ApprovalRequest? @relation(fields: [approval_request_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  roles               Role?            @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("approval_steps")
  @@schema("auth")
}

model ApprovalDelegation {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  from_user  String?   @db.Uuid
  to_user    String?   @db.Uuid
  start_date DateTime? @db.Timestamp(6)
  end_date   DateTime? @db.Timestamp(6)
  is_active  Boolean?  @default(true)

  @@map("approval_delegations")
  @@schema("auth")
}

// ─── System Settings (Configurable Approval Limits) ─────────────────────────
model SystemSetting {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String    @db.VarChar(100)
  value       String
  label       String?   @db.VarChar(200)
  description String?
  category    String?   @db.VarChar(50)
  company_id  String?   @db.Uuid
  company     Company?  @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @db.Timestamp(6)

  @@unique([key, company_id])
  @@map("system_settings")
  @@schema("auth")
}

// ─── Profit Share Rules ─────────────────────────────────────────────────────
model ProfitShareRule {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String      @db.VarChar(200)
  entity_type     String      @db.VarChar(50) // "PROJECT", "DEPARTMENT", "COMPANY"
  entity_id       String?     @db.Uuid
  company_id      String?     @db.Uuid
  department_id   String?     @db.Uuid
  project_id      String?     @db.Uuid
  partner_a_name  String?     @db.VarChar(200)
  partner_a_share Decimal?    @db.Decimal // e.g. 50.00
  partner_b_name  String?     @db.VarChar(200)
  partner_b_share Decimal?    @db.Decimal // e.g. 50.00
  is_active       Boolean?    @default(true)
  created_at      DateTime?   @default(now()) @db.Timestamp(6)
  updated_at      DateTime?   @db.Timestamp(6)
  company         Company?    @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  department      Department? @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project         Project?    @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("profit_share_rules")
  @@schema("auth")
}

// ─── Operational Modules (Vendors, POs, Payroll, Quotations, Expenses, Progress) ────────────────

model Vendor {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id     String?   @db.Uuid
  department_id  String?   @db.Uuid
  name           String    @db.VarChar(200)
  email          String?   @db.VarChar(150)
  phone          String?   @db.VarChar(50)
  contact_person String?   @db.VarChar(150)
  address        String?
  tax_id         String?   @db.VarChar(50)
  services       String?
  category       String?   @db.VarChar(100)
  rating         Decimal?  @db.Decimal
  bank_details   Json?
  attachments    Json?
  status         String?   @default("pending") @db.VarChar(50)
  created_by     String?   @db.Uuid
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @db.Timestamp(6)
  deleted_at     DateTime? @db.Timestamp(6)

  company           Company?          @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  department        Department?       @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator           User?             @relation("VendorCreator", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchase_orders   PurchaseOrder[]
  supplier_invoices SupplierInvoice[]

  rfq_vendors           RFQVendor[]
  vendor_quotes         VendorQuote[]
  comparison_selections ComparisonEngine[]
  procurement_items     ProcurementPlanItem[]

  @@map("vendors")
  @@schema("auth")
}

model PurchaseOrder {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  po_number       String    @unique @db.VarChar(100)
  company_id      String?   @db.Uuid
  department_id   String?   @db.Uuid
  project_id      String?   @db.Uuid
  vendor_id       String?   @db.Uuid
  amount          Decimal   @db.Decimal
  status          String?   @default("draft") @db.VarChar(50)
  // Week 5: tracks whether vendor delivery is pending / partial / complete
  delivery_status String?   @default("pending") @db.VarChar(20)
  created_by      String?   @db.Uuid
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @db.Timestamp(6)
  deleted_at      DateTime? @db.Timestamp(6)

  company    Company?    @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  department Department? @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project    Project?    @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendor     Vendor?     @relation(fields: [vendor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator    User?       @relation("POCreator", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  items          PurchaseOrderItem[]
  requisition_id String?              @db.Uuid
  rfq_id         String?              @db.Uuid
  quote_id       String?              @db.Uuid
  delivery_terms String?
  payment_terms  String?
  subtotal       Decimal?             @db.Decimal
  vat_amount     Decimal?             @db.Decimal
  total_amount   Decimal?             @db.Decimal
  requisition    PurchaseRequisition? @relation(fields: [requisition_id], references: [id])
  rfq            RFQ?                 @relation(fields: [rfq_id], references: [id])
  quote          VendorQuote?         @relation(fields: [quote_id], references: [id])

  invoices SupplierInvoice[]
  grns     GoodsReceiptNote[]

  notes             String?
  terms_conditions  String?
  attachments       Json?
  procurement_items ProcurementPlanItem[]
  deliveryTrackings DeliveryTracking[]

  @@map("purchase_orders")
  @@schema("auth")
}

